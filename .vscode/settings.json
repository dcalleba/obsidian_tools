{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.activateEnvironment": true,
  "python.analysis.typeCheckingMode": "basic",
  "files.exclude": {
    "**/.DS_Store": true,
    "**/__pycache__": true,
    "**/*.egg-info": true
  },
  "search.exclude": {
    "**/.venv": true,
    "**/__pycache__": true,
    "**/*.egg-info": true,
    "**/diagnostics": true,
    "**/exports": true,
    "**/obsidian_media_report*.json": true,
    "**/obsidian_media_diagnosis*.json": true
  }
}
